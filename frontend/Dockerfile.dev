FROM node:20-alpine

WORKDIR /app

# Install dependencies (cached unless package-lock changes)
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts

# Copy full source (will be overridden at runtime by the bind mount on src/)
COPY . .

ENV HOST=0.0.0.0
ENV PORT=3000

EXPOSE 3000

# vite dev — hot module replacement (HMR) enabled by default
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
