# ─────────────────────────────────────────────────────────────────────────────
# Root-level compose variables
# Copy to .env and fill in before running: docker compose up --build -d
#
# NOTE: Backend secrets (DATABASE_URL, API keys, etc.) go in backend/.env
#       See backend/.env.example for the full list.
# ─────────────────────────────────────────────────────────────────────────────

# URL the browser uses to reach the backend API.
# Local:      http://localhost:8000
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000
