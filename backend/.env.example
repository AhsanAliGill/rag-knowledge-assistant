APP_NAME="Company Knowledge Assistant"
DEBUG=false

# Admin seed user — used by Alembic migration a1b2c3d4e5f6
ADMIN_SEED_PASSWORD=your-admin-password-here

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/knowledge_db
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/knowledge_db_test

SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

CORS_ORIGINS=["http://localhost:3000"]

# ── RAG Pipeline ──────────────────────────────────────────────────────────────

# OpenRouter — LLM (generation + HyDE) AND Embeddings
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4-6
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_BATCH_SIZE=100

# Qdrant Cloud — Vector Database
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=rag_documents

# Cohere — Reranker
COHERE_API_KEY=your-cohere-api-key-here
COHERE_RERANK_MODEL=rerank-english-v3.0

# RAG Retrieval Tuning
RAG_DENSE_K=20
RAG_SPARSE_K=20
RAG_DENSE_WEIGHT=0.6
RAG_RERANK_TOP_N=5
RAG_RELEVANCE_THRESHOLD=0.25
RAG_CONTEXT_TOKEN_BUDGET=3500

# Chunking
PARENT_CHUNK_SIZE=2000
CHILD_CHUNK_SIZE=400
CHILD_CHUNK_OVERLAP=80

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
MAX_PAGES=500
MAX_UPLOADS_PER_DAY=10

# Local Storage Paths
BM25_INDEX_DIR=bm25_indexes
GROUND_TRUTH_DIR=ground_truth
