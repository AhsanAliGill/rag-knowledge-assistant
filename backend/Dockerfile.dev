FROM python:3.11-slim

# uv from official image — no pip install needed
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# All system libs in one layer (dev image doesn't need to be size-optimised)
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libpq-dev \
        libffi-dev \
        libpq5 \
        libmagic1 \
        poppler-utils \
        tesseract-ocr \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy manifests first → this layer is cached until uv.lock changes
COPY pyproject.toml uv.lock README.md ./

# Install all deps (including dev group) but NOT the project package yet
# Doing this before COPY src/ lets Docker cache the heavy dep layer
RUN uv sync --frozen --no-install-project

# Now copy source and install the project itself
COPY src/ src/
RUN uv sync --frozen

COPY alembic/ alembic/
COPY alembic.ini .
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app/src

EXPOSE 8000

ENTRYPOINT ["/entrypoint.sh"]
